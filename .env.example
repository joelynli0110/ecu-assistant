# Credential-free local fallback (default)
ME_ECU_LLM_PROVIDER=none
ME_ECU_EMBEDDING_PROVIDER=hash

# Recommended fully local model path:
# ME_ECU_LLM_PROVIDER=ollama
# ME_ECU_LLM_MODEL=llama3.2
# ME_ECU_EMBEDDING_PROVIDER=ollama
# ME_ECU_EMBEDDING_MODEL=nomic-embed-text

# Hosted OpenAI path:
# OPENAI_API_KEY=replace-me
# ME_ECU_LLM_PROVIDER=openai
# ME_ECU_LLM_MODEL=gpt-4o-mini
# ME_ECU_EMBEDDING_PROVIDER=openai
# ME_ECU_EMBEDDING_MODEL=text-embedding-3-small

# Local MLflow:
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
ME_ECU_MLFLOW_EXPERIMENT=ecu-assistant
